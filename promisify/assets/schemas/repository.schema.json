{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/norms/v1/repository.schema.json",
  "title": "Normative repository descriptor",
  "type": "object",
  "required": ["apiVersion", "kind", "metadata", "spec"],
  "properties": {
    "apiVersion": {"const": "norms/v1"},
    "kind": {"const": "Repository"},
    "metadata": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": {"type": "string", "minLength": 1},
        "description": {"type": "string"}
      },
      "additionalProperties": false
    },
    "spec": {
      "type": "object",
      "required": ["promiseRoot", "assessmentRoot", "trustViewRoot"],
      "properties": {
        "promiseRoot": {"const": ".norms/promises"},
        "assessmentRoot": {"const": ".norms/assessments"},
        "trustViewRoot": {"const": ".norms/views"},
        "reportRoot": {"type": "string", "default": ".norms/reports"},
        "defaultView": {"type": "string", "pattern": "^[a-z0-9][a-z0-9_-]*$"}
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
